var currentLang = "en";
var isAdmin = false;

function applyLanguage(lang){
  currentLang = lang;
  var dict = I18N[lang];

  document.querySelectorAll("[data-i18n]").forEach(function(el){
    var key = el.getAttribute("data-i18n");
    if(dict[key] !== undefined) el.innerHTML = dict[key];
  });

  // composite headline blocks (line break + em)
  var homeTitle = document.querySelector('[data-i18n-html="home_title"]');
  if(homeTitle) homeTitle.innerHTML = dict.home_title_l1 + '<br>' + (lang==="ko" ? '' : 'no one else ') + '<em>' + dict.home_title_em + '</em>';

  var aboutTitle = document.querySelector('[data-i18n-html="about_title"]');
  if(aboutTitle) aboutTitle.innerHTML = (lang==="ko" ? '' : 'About the ') + '<em>' + dict.about_title_em + (lang==="ko" ? '' : '.') + '</em>';

  var missionTitle = document.querySelector('[data-i18n-html="mission_title"]');
  if(missionTitle) missionTitle.innerHTML = dict.mission_title_l1 + '<br><em>' + dict.mission_title_em + '</em>';

  var opsTitle = document.querySelector('[data-i18n-html="ops_title"]');
  if(opsTitle) opsTitle.innerHTML = dict.ops_title_l1 + '<br><em>' + dict.ops_title_em + '</em>';

  var contactTitle = document.querySelector('[data-i18n-html="contact_title"]');
  if(contactTitle) contactTitle.innerHTML = (lang==="ko" ? '' : 'Reach the ') + '<em>' + dict.contact_title_em + '</em>' + (lang==="ko" ? '로 연락하기.' : '');

  document.documentElement.lang = lang === "ko" ? "ko" : "en";
  renderBoard();
}

/* ================= auth ================= */
function renderAuthArea(){
  var area = document.getElementById("authArea");
  if(isAdmin){
    area.innerHTML =
      '<div class="auth-chip"><span class="dot"></span><span>지휘관 모드 · admin</span></div>' +
      '<button class="auth-btn" onclick="logout()">' + I18N.ko.logout_btn_nav + '</button>';
  } else {
    area.innerHTML =
      '<button class="auth-btn" onclick="showPage(\'loginPage\')" data-i18n="login_btn_nav">' + I18N[currentLang].login_btn_nav + '</button>';
  }
}

function doLogin(e){
  e.preventDefault();
  var id = document.getElementById("loginId").value.trim();
  var pw = document.getElementById("loginPw").value;
  var status = document.getElementById("loginStatus");

  if(id === "admin" && pw === "admin123"){
    isAdmin = true;
    status.style.color = "var(--accent)";
    status.textContent = I18N.ko.login_success;
    applyLanguage("ko");
    renderAuthArea();
    setTimeout(function(){ showPage("homePage"); }, 500);
  } else {
    status.style.color = "var(--danger)";
    status.textContent = I18N[currentLang].login_error;
  }
  return false;
}

function logout(){
  isAdmin = false;
  applyLanguage("en");
  renderAuthArea();
  showPage("homePage");
}

/* ================= navigation ================= */
function showPage(id){
  document.querySelectorAll(".page").forEach(function(p){ p.classList.remove("active"); });
  document.getElementById(id).classList.add("active");

  document.querySelectorAll(".nav-inner a").forEach(function(a){ a.classList.remove("active"); });
  var navMap = { homePage:"nav-homePage", aboutPage:"nav-aboutPage", detailJinoo:"nav-aboutPage",
                 detailChris:"nav-aboutPage", detailSion:"nav-aboutPage", missionPage:"nav-missionPage",
                 operationsPage:"nav-operationsPage", boardPage:"nav-boardPage", contactPage:"nav-contactPage" };
  if(navMap[id]) document.getElementById(navMap[id]).classList.add("active");

  window.scrollTo(0,0);
}

/* ================= contact form ================= */
function handleSubmit(e){
  e.preventDefault();
  document.getElementById("formStatus").textContent = I18N[currentLang].form_status;
  e.target.reset();
  return false;
}

/* ================= board (in-memory only, resets on reload) ================= */
var boardPosts = [];

function submitPost(e){
  e.preventDefault();
  var author = document.getElementById("postAuthor").value.trim();
  var title = document.getElementById("postTitle").value.trim();
  var body = document.getElementById("postBody").value.trim();
  if(!author || !title || !body) return false;

  boardPosts.unshift({ author:author, title:title, body:body, time:new Date().toLocaleString() });
  e.target.reset();
  renderBoard();
  return false;
}

function deletePost(index){
  boardPosts.splice(index,1);
  renderBoard();
}

function renderBoard(){
  var list = document.getElementById("boardList");
  if(!list) return;

  if(boardPosts.length === 0){
    list.innerHTML = '<p class="contact-note">' + I18N[currentLang].board_empty + '</p>';
    return;
  }

  list.innerHTML = boardPosts.map(function(post, i){
    var delBtn = isAdmin ? '<button class="del-btn" onclick="deletePost(' + i + ')">' + I18N[currentLang].btn_delete + '</button>' : '';
    return '<div class="board-post">' +
      '<div class="board-post-top"><h4>' + escapeHtml(post.title) + '</h4><span class="board-post-meta">' + escapeHtml(post.author) + ' · ' + post.time + '</span></div>' +
      '<p>' + escapeHtml(post.body) + '</p>' +
      delBtn +
      '</div>';
  }).join('');
}

function escapeHtml(str){
  var d = document.createElement('div');
  d.textContent = str;
  return d.innerHTML;
}

/* ================= init ================= */
applyLanguage("en");
renderAuthArea();
renderBoard();
showPage("homePage");
</script>

